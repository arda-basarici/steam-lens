# --- secrets (never in source; env or secret store only) ---
.env
.env.*
*.pem
*.key

# --- working files (disposable by design) ---
WHITEBOARD.md

# --- data & runtime artifacts (mostly regenerable; but data/steamlens.sqlite3 is
#     the BOUGHT label census — Drive-backed + hash-manifested, never re-derivable) ---
data/
logs/
*.sqlite
*.db

# --- generated docs (pdoc output; regenerated from docstrings) ---
docs/api/

# --- python ---
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- OS noise ---
Thumbs.db
.DS_Store

# bake-off response archive — the durable raw provider bodies (content-keyed);
# re-read on resume so a re-invoked run never re-buys
probes/captures/bakeoff/bakeoff.sqlite3
