# --- secrets (never in source; env or secret store only) ---
.env
.env.*
*.pem
*.key

# --- working files (disposable by design) ---
WHITEBOARD.md

# --- data & runtime artifacts (regenerable; provenance documented in-repo) ---
data/
logs/
*.sqlite
*.db

# --- generated docs (pdoc output; regenerated from docstrings) ---
docs/api/

# --- python ---
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- OS noise ---
Thumbs.db
.DS_Store

# bake-off resume cache — raw bodies live in each run's raw.jsonl capture
probes/captures/bakeoff/bakeoff.sqlite3
